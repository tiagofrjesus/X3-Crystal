## TED Code Edition
$TRT_TED
GOK=1
Trbegin [ARM]
 Raz [F:ARM]
 # K = 0 # A ne pas Faire !
 For I=1 To NBRLEG
  Filter [TED] Where LEG=[L]TABLEG(I) | LEG="" Order By Key CLE=CODEDT Asc ; LEG Desc
  For [TED]CLE(1)
   K += 1
   [F:ARM]RPTCOD = ETAT
   [F:ARM]USR    = GUSER
   [F:ARM]NUMREQ = NUMREQ
   [F:ARM]NUMLIG = K
   [F:ARM]CLEA1 = [F:TED]CODEDT
   [F:ARM]CLEA2 = [F:TED]LEG
   [F:ARM]CLEA3 = [L]TABLEG(I)
   [F:ARM]CLEA4 = "TABCODEDT"
   Write [F:ARM]
   If fstat
    GOK = 0 : Call FSTA("ARM") From GLOCK : Break 2
   Endif
  Next
 Next
 Filter [TED]
 If GOK=0 : Rollback : Return : Endif
Commit
Return

