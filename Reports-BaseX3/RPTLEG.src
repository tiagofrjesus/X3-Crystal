## TDA - Code escompte-agio
$TRT_TDA
GOK=1
Trbegin [ARM]
 Raz [F:ARM]
 # K = 0 A ne pas faire !
 For I=1 To NBRLEG
  Filter [TDA] Where LEG=[L]TABLEG(I) | LEG="" Order By Key CLE=DEP Asc ; LEG Desc
  For [TDA]CLE(1)
   K += 1
   [F:ARM]RPTCOD = ETAT
   [F:ARM]USR    = GUSER
   [F:ARM]NUMREQ = NUMREQ
   [F:ARM]NUMLIG = K
   [F:ARM]CLEA1 = [F:TDA]DEP
   [F:ARM]CLEA2 = [F:TDA]LEG
   [F:ARM]CLEA3 = [L]TABLEG(I)
   [F:ARM]CLEA4 = "TABDEPAGIO"
   Write [F:ARM]
   If fstat
    GOK = 0 : Call FSTA("ARM") From GLOCK : Break 2
   Endif
  Next
  # If the invoice doesn't have an early discount, we have to create an empty record
  # in order that the link with the AREPORT table works in Crystal report
  K += 1
  [F:ARM]RPTCOD = ETAT
  [F:ARM]USR    = GUSER
  [F:ARM]NUMREQ = NUMREQ
  [F:ARM]NUMLIG = K
  [F:ARM]CLEA1 = ""
  [F:ARM]CLEA2 = ""
  [F:ARM]CLEA3 = [L]TABLEG(I)
  [F:ARM]CLEA4 = "TABDEPAGIO"
  Write [F:ARM]
  If fstat
   GOK = 0 : Call FSTA("ARM") From GLOCK : Break
  Endif
 Next
 Filter [TDA]
 If GOK=0 : Rollback : Return : Endif
Commit
Return

